{
  "name": "dchat-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "D Chat Desktop - Cross-platform AI chat application",
  "workspaces": [
    "packages/shared",
    "packages/backend",
    "packages/frontend",
    "packages/electron"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "npm run dev -w @dchat/backend",
    "dev:frontend": "npm run dev -w @dchat/frontend",
    "dev:electron": "npm run dev -w @dchat/electron-app",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "npm run build -w @dchat/backend",
    "build:frontend": "npm run build -w @dchat/frontend",
    "build:electron": "npm run build -w @dchat/electron-app",
    "test": "npm run test -w @dchat/backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.7.0"
  }
}

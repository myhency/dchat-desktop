{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@dchat/shared": ["../shared/src/index.ts"],
      "@dchat/shared/*": ["../shared/src/*"]
    }
  },
  "include": ["src/**/*"]
}
